generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native"]
  engineType    = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ReminderStatus {
  scheduled
  processing
  completed
  cancelled
}

enum ReminderCategory {
  general
  birthday
  event
  conflict
  busy_time
}

enum ReminderRecurrence {
  none
  daily
  weekly
  monthly
  yearly
}

model User {
  id          String  @id @default(uuid())
  refId       String  @unique @default(uuid()) @map("ref_id")
  firstName   String? @map("first_name")
  lastName    String? @map("last_name")
  email       String? @unique
  phoneNumber String? @unique @map("phone_number")

  title String?
  bio   String? @db.Text

  timezone      String    @default("America/Los_Angeles")
  isActive      Boolean   @default(true) @map("is_active")
  lastMessageAt DateTime? @map("last_message_at")

  // Google OAuth — calendar now, gmail later
  googleEmail                String?   @map("google_email")
  googleRefreshToken         String?   @map("google_refresh_token")
  googleAccessToken          String?   @map("google_access_token")
  googleAccessTokenExpiresAt DateTime? @map("google_access_token_expires_at")
  calendarConnectedAt        DateTime? @map("calendar_connected_at")

  // One-time magic link for kicking off the OAuth flow from iMessage
  connectToken          String?   @unique @map("connect_token")
  connectTokenExpiresAt DateTime? @map("connect_token_expires_at")

  sentMessages     ChannelMessage[] @relation("SentChannelMessages")
  receivedMessages ChannelMessage[] @relation("ReceivedChannelMessages")

  adminNotes      String?          @map("admin_notes") @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  analyticsEvents AnalyticsEvent[]
  reminders       Reminder[]

  @@index([refId])
  @@index([phoneNumber])
  @@map("users")
}

model ChannelMessage {
  id            Int       @id @default(autoincrement())
  fromUserId    String?   @map("from_user_id")
  fromUser      User?     @relation("SentChannelMessages", fields: [fromUserId], references: [id])
  toUserId      String?   @map("to_user_id")
  toUser        User?     @relation("ReceivedChannelMessages", fields: [toUserId], references: [id])
  messageHandle String?   @unique @map("message_handle")
  content       String?   @db.Text
  mediaUrl      String?   @map("media_url")
  sendblueData  Json?     @map("sendblue_data")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@map("channel_messages")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event, createdAt])
  @@index([userId])
  @@map("analytics_events")
}

model Reminder {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  note        String?            @db.Text
  category    ReminderCategory   @default(general)
  status      ReminderStatus     @default(scheduled)
  recurrence  ReminderRecurrence @default(none)
  interval    Int                @default(1)
  remindAt    DateTime           @map("remind_at")
  timezone    String
  lastSentAt  DateTime?          @map("last_sent_at")
  cancelledAt DateTime?          @map("cancelled_at")
  failedCount Int                @default(0) @map("failed_count")
  lastError   String?            @map("last_error") @db.Text
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([status, remindAt])
  @@index([category, remindAt])
  @@map("reminders")
}
