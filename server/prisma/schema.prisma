generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native"]
  engineType    = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ConnectorProvider {
  GOOGLE
  MICROSOFT
  APPLE
  CALDAV
  CARDDAV
  TODOIST
}

enum ConnectorDomain {
  CALENDAR
  CONTACTS
  TASKS
  EMAIL
}

enum ConnectedAccountStatus {
  ACTIVE
  NEEDS_REAUTH
  ERROR
  REVOKED
  DISCONNECTED
}

enum PendingActionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXECUTED
  EXPIRED
  FAILED
}

enum ActionLogStatus {
  SUCCEEDED
  FAILED
  UNDONE
}

model User {
  id          String  @id @default(uuid())
  refId       String  @unique @default(uuid()) @map("ref_id")
  firstName   String? @map("first_name")
  lastName    String? @map("last_name")
  email       String? @unique
  phoneNumber String? @unique @map("phone_number")

  title String?
  bio   String? @db.Text

  timezone      String    @default("America/Los_Angeles")
  isActive      Boolean   @default(true) @map("is_active")
  lastMessageAt DateTime? @map("last_message_at")

  sentMessages     ChannelMessage[] @relation("SentChannelMessages")
  receivedMessages ChannelMessage[] @relation("ReceivedChannelMessages")

  connectedAccounts ConnectedAccount[]
  externalResources ExternalResource[]
  personAliases     PersonAlias[]
  pendingActions    PendingAction[]
  actionLogs        ActionLog[]

  adminNotes      String?          @map("admin_notes") @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  analyticsEvents AnalyticsEvent[]

  @@index([refId])
  @@index([phoneNumber])
  @@map("users")
}

model ChannelMessage {
  id            Int       @id @default(autoincrement())
  fromUserId    String?   @map("from_user_id")
  fromUser      User?     @relation("SentChannelMessages", fields: [fromUserId], references: [id])
  toUserId      String?   @map("to_user_id")
  toUser        User?     @relation("ReceivedChannelMessages", fields: [toUserId], references: [id])
  messageHandle String?   @unique @map("message_handle")
  content       String?   @db.Text
  mediaUrl      String?   @map("media_url")
  sendblueData  Json?     @map("sendblue_data")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@map("channel_messages")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event, createdAt])
  @@index([userId])
  @@map("analytics_events")
}

model ConnectedAccount {
  id                 String                 @id @default(uuid())
  userId             String                 @map("user_id")
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           ConnectorProvider
  status             ConnectedAccountStatus @default(ACTIVE)
  accountEmail       String?                @map("account_email")
  accountName        String?                @map("account_name")
  externalAccountId  String                 @map("external_account_id")
  accessTokenCiphertext  String?            @map("access_token_ciphertext") @db.Text
  refreshTokenCiphertext String?            @map("refresh_token_ciphertext") @db.Text
  idTokenCiphertext      String?            @map("id_token_ciphertext") @db.Text
  tokenType          String?                @map("token_type")
  scopes             String[]               @default([])
  expiresAt          DateTime?              @map("expires_at")
  lastSyncedAt       DateTime?              @map("last_synced_at")
  lastValidatedAt    DateTime?              @map("last_validated_at")
  lastErrorAt        DateTime?              @map("last_error_at")
  lastErrorCode      String?                @map("last_error_code")
  lastErrorMessage   String?                @map("last_error_message") @db.Text
  metadata           Json?
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  externalResources ExternalResource[]
  personAliases     PersonAlias[]
  pendingActions    PendingAction[]
  actionLogs        ActionLog[]

  @@unique([userId, provider, externalAccountId])
  @@index([userId, provider])
  @@index([status, updatedAt])
  @@map("connected_accounts")
}

model ExternalResource {
  id               String          @id @default(uuid())
  userId           String          @map("user_id")
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccountId String        @map("connected_account_id")
  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  domain           ConnectorDomain
  resourceType     String          @map("resource_type")
  externalId       String          @map("external_id")
  parentExternalId String?         @map("parent_external_id")
  displayName      String?         @map("display_name")
  remoteUrl        String?         @map("remote_url")
  etag             String?
  fingerprint      String?
  sourceUpdatedAt  DateTime?       @map("source_updated_at")
  syncedAt         DateTime?       @map("synced_at")
  metadata         Json?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  personAliases PersonAlias[]

  @@unique([connectedAccountId, domain, externalId])
  @@index([userId, domain, resourceType])
  @@index([displayName])
  @@map("external_resources")
}

model PersonAlias {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccountId String?        @map("connected_account_id")
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  externalResourceId String?        @map("external_resource_id")
  externalResource ExternalResource? @relation(fields: [externalResourceId], references: [id], onDelete: SetNull)
  alias            String
  normalizedAlias  String           @map("normalized_alias")
  displayName      String?          @map("display_name")
  metadata         Json?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([userId, normalizedAlias])
  @@index([connectedAccountId])
  @@index([externalResourceId])
  @@map("person_aliases")
}

model PendingAction {
  id               String              @id @default(uuid())
  userId           String              @map("user_id")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccountId String?           @map("connected_account_id")
  connectedAccount ConnectedAccount?   @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  domain           ConnectorDomain
  operation        String
  status           PendingActionStatus @default(PENDING)
  confirmationToken String             @unique @default(uuid()) @map("confirmation_token")
  summary          String?             @db.Text
  requestPayload   Json                @map("request_payload")
  proposedResult   Json?               @map("proposed_result")
  expiresAt        DateTime?           @map("expires_at")
  confirmedAt      DateTime?           @map("confirmed_at")
  executedAt       DateTime?           @map("executed_at")
  failedAt         DateTime?           @map("failed_at")
  lastError        String?             @map("last_error") @db.Text
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  actionLog ActionLog?

  @@index([userId, status, createdAt])
  @@index([expiresAt])
  @@map("pending_actions")
}

model ActionLog {
  id               String          @id @default(uuid())
  userId           String          @map("user_id")
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccountId String?       @map("connected_account_id")
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  pendingActionId  String?         @unique @map("pending_action_id")
  pendingAction    PendingAction?  @relation(fields: [pendingActionId], references: [id], onDelete: SetNull)
  domain           ConnectorDomain
  operation        String
  status           ActionLogStatus @default(SUCCEEDED)
  summary          String?         @db.Text
  beforeState      Json?           @map("before_state")
  afterState       Json?           @map("after_state")
  undoPayload      Json?           @map("undo_payload")
  undoneAt         DateTime?       @map("undone_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([userId, domain, createdAt])
  @@map("action_logs")
}
