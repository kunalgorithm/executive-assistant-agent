# See README "Environments" for the canonical URLs per env.
# Local dev: ngrok domain is `ea.ngrok.dev` — run `ngrok http --url=ea.ngrok.dev 80`.
# Staging:   API at https://api.ea.getsayla.com, frontend at https://ea.getsayla.com.

# Where the frontend lives (origin allowlist + base URL for connect links).
# Local:   http://localhost:3000
# Staging: https://ea.getsayla.com
CLIENT_URL=

DATABASE_URL=

GEMINI_API_KEY=

# SendBlue iMessage gateway. Webhook base URL is what SendBlue POSTs to.
# Local:   https://ea.ngrok.dev
# Staging: https://api.ea.getsayla.com
SENDBLUE_API_KEY=
SENDBLUE_SECRET=
SENDBLUE_FROM_NUMBER=
SENDBLUE_WEBHOOK_BASE_URL=
SENDBLUE_WEBHOOK_SECRET=

# Google OAuth for Calendar, Contacts, and Tasks. Register the redirect URI
# in the Google Cloud console.
# Local:   https://ea.ngrok.dev/api/auth/google/callback
# Staging: https://api.ea.getsayla.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Google Places API (New) — server-side key for restaurant search.
# Enable "Places API (New)" in Google Cloud Console (separate from OAuth).
# No per-user auth required — this is a server-side key.
GOOGLE_MAPS_API_KEY=

# Optional single-owner lock. Leave empty in local to accept any inbound number.
OWNER_PHONE_NUMBER=

JWT_SECRET=
